// Copy this file to secrets.h and fill in your own values.
// secrets.h is gitignored so your credentials never leave your machine.
//
// First-time setup:
//   cp esp32/src/secrets.h.example esp32/src/secrets.h
//   edit esp32/src/secrets.h
//
// After that, just `git pull` — secrets.h stays untouched.

#pragma once

// WiFi
#define SECRET_WIFI_SSID   "your-wifi-ssid"
#define SECRET_WIFI_PASS   "your-wifi-password"

// MQTT broker (Pi IP on your LAN, or mqtt hostname)
#define SECRET_MQTT_SERVER "192.168.1.10"
#define SECRET_MQTT_PORT   1883

// Station identity — set this per ESP32 to match your Supabase stations table.
// Station 1 = Pi, so ESP32s are usually 2, 3, ...
#define SECRET_STATION_ID  2
